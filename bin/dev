#!/usr/bin/env ruby

require "fileutils"

# Check if foreman is available
if system("which foreman > /dev/null 2>&1")
  # Use foreman if available
  exec "foreman start -f Procfile.dev"
else
  # Fallback: start both processes in background
  puts "Starting development servers..."

  # Start Vite dev server in background
  js_pid = spawn("bin/vite dev")

  # Start Rails server in foreground
  begin
    exec "./bin/rails", "server", *ARGV
  ensure
    # Kill the JavaScript process when Rails server stops
    Process.kill("TERM", js_pid) rescue nil
  end
end
