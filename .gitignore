# See https://help.github.com/articles/ignoring-files for more about ignoring files.
# Editor/OS-generated files should go in your global gitignore (~/.config/git/ignore)

# === Bundler ===
/.bundle
/vendor/bundle/
/vendor/cache/
/vendor/assets/
/vendor/ruby/

# === Rails Environment Files ===
/.env*
/config/master.key

# === Logs and Temp Files ===
/log/*
!/log/.keep

/tmp/*
!/tmp/.keep

# Specific subdirs we want to keep
/tmp/pids/*
!/tmp/pids/
/tmp/pids/.keep

/tmp/storage/*
!/tmp/storage/
/tmp/storage/.keep

/tmp/cache/
/tmp/capybara/

# === Development Uploads and Cache ===
/storage/*
!/storage/.keep

# === Node/Yarn ===
/node_modules
/yarn-error.log

# === REPL and Debug History ===
.byebug_history
.irb_history
.pry_history
*.log
*.pid
*.pid.lock

# === Coverage Reports ===
/coverage/

# === RSpec ===
.rspec
/spec/examples.txt

# === Assets ===
/public/assets/
/public/packs/
/public/packs-test/

# === VSCode ===
.vscode/

# === Backup and autosave files ===
*.swp
*.swo
*~
*.bak
*.bak_[0-9]*
*.orig
*.rej

# === OS-specific ===
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
/encryptor.link
