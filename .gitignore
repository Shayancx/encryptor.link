# See https://help.github.com/articles/ignoring-files for more about ignoring files.
# Editor/OS-generated files should go in your global gitignore (~/.config/git/ignore)

# === Bundler ===
/.bundle

# === Rails Environment Files ===
/.env*
/config/master.key

# === Logs and Temp Files ===
/log/*
!/log/.keep

/tmp/*
!/tmp/.keep

# Specific subdirs we want to keep
/tmp/pids/*
!/tmp/pids/
/tmp/pids/.keep

/tmp/storage/*
!/tmp/storage/
/tmp/storage/.keep

# === Development Uploads and Cache ===
/storage/*
!/storage/.keep

# === Node/Yarn ===
/node_modules
/yarn-error.log

# === Byebug, Pry, or REPL history ===
.byebug_history
.irb_history
.pry_history

# === IDEs and Editors ===
*.swp
*.swo
*~
*.bak
*.bak_[0-9]*

# === macOS ===
.DS_Store

# === Windows ===
Thumbs.db
ehthumbs.db
Desktop.ini

# === Linux ===
*~

# === RubyMine ===
.idea

# === VSCode ===
.vscode/

# === JetBrains ===
*.iml
/.idea/

# === Backup and autosave files ===
*.orig
*.rej

# === Misc ===
/coverage/
/doc/
/public/assets/
/public/packs/
/public/packs-test/
/spec/examples.txt
/tmp/pids/
tmp/cache/
