}

/* Display output styles */
.rich-content-output {
  background-color: var(--gh-bg-secondary);
  border: 1px solid var(--gh-border-color);
  border-radius: 6px;
  padding: 16px;
  min-height: 200px;
  overflow-x: auto;
}

/* Fixed Rich Text Editor Styles */
.rich-editor-container {
  border: 1px solid var(--gh-border-color);
  border-radius: 6px;
  overflow: hidden;
  margin-bottom: 0; /* Remove bottom margin */
}

.rich-editor-toolbar {
  background-color: #1e1e1e;
  border-bottom: 1px solid #333;
  padding: 4px 6px; /* Smaller padding */
  display: flex;
  flex-wrap: nowrap; /* Keep buttons in a single row */
  gap: 0; /* Remove gap */
  height: 32px; /* Fixed height for toolbar */
}

.rich-editor-button {
  background-color: transparent;
  border: none;
  color: #ccc;
  width: 28px; /* Smaller button width */
  height: 24px; /* Smaller button height */
  border-radius: 3px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4px;
  margin: 0 1px; /* Small margin between buttons */
  font-size: 12px; /* Smaller font size for heading buttons */
}

.rich-editor-button:hover {
  background-color: #333;
}

.rich-editor-button.active {
  background-color: rgba(0, 122, 255, 0.2);
  color: #fff;
}

.rich-editor-divider {
  width: 1px;
  height: 20px; /* Smaller divider */
  background-color: #333;
  margin: 0 4px;
}

.rich-editor-content {
  background-color: #0d1117;
  color: #e6edf3;
  height: 200px; /* Fixed height matching original textarea */
  min-height: 0; /* Override min-height */
  padding: 8px 12px;
  outline: none;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
  font-size: 14px;
  overflow-y: auto;
}

.rich-editor-content[contenteditable=true]:empty:before {
  content: attr(placeholder);
  color: #666;
}

/* SVG icon sizes */
.rich-editor-button svg {
  width: 14px;
  height: 14px;
}

/* Styling for edited content */
.rich-editor-content h1, .rich-editor-content h2, .rich-editor-content h3 {
  margin-top: 0.5rem;
  margin-bottom: 0.5rem;
  font-weight: 600;
}

.rich-editor-content h1 {
  font-size: 1.5rem;
}

.rich-editor-content h2 {
  font-size: 1.3rem;
}

.rich-editor-content h3 {
  font-size: 1.15rem;
}

