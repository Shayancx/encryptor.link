<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Account Dashboard</h2>
    <%= link_to "Back to Encryptor", root_path, class: "btn btn-outline-secondary" %>
  </div>

  <!-- Quick Stats -->
  <div class="row mb-4">
    <div class="col-md-3 mb-3">
      <div class="gh-card">
        <div class="gh-card-body text-center">
          <h4 class="mb-1"><%= @total_messages %></h4>
          <p class="text-muted mb-0">Total Messages</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 mb-3">
      <div class="gh-card">
        <div class="gh-card-body text-center">
          <h4 class="mb-1"><%= @active_messages %></h4>
          <p class="text-muted mb-0">Active Messages</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 mb-3">
      <div class="gh-card">
        <div class="gh-card-body text-center">
          <h4 class="mb-1"><%= @expired_messages %></h4>
          <p class="text-muted mb-0">Expired Messages</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 mb-3">
      <div class="gh-card">
        <div class="gh-card-body text-center">
          <h4 class="mb-1"><%= Current.user.email_address.split('@').first.capitalize %></h4>
          <p class="text-muted mb-0">User Account</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Navigation Cards -->
  <div class="row">
    <div class="col-md-6 mb-4">
      <div class="gh-card gh-card-elevated">
        <div class="gh-card-header">
          <h5 class="mb-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Message History
          </h5>
        </div>
        <div class="gh-card-body">
          <p class="text-muted">View and manage your encrypted messages</p>
          <%= link_to "View Messages", account_messages_path, class: "btn btn-primary" %>
        </div>
      </div>
    </div>

    <div class="col-md-6 mb-4">
      <div class="gh-card gh-card-elevated">
        <div class="gh-card-header">
          <h5 class="mb-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1 1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
            Preferences
          </h5>
        </div>
        <div class="gh-card-body">
          <p class="text-muted">Configure your default settings</p>
          <%= link_to "Manage Preferences", account_preferences_path, class: "btn btn-primary" %>
        </div>
      </div>
    </div>

    <div class="col-md-6 mb-4">
      <div class="gh-card gh-card-elevated">
        <div class="gh-card-header">
          <h5 class="mb-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="m7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            Security
          </h5>
        </div>
        <div class="gh-card-body">
          <p class="text-muted">Change password and security settings</p>
          <%= link_to "Security Settings", account_security_path, class: "btn btn-primary" %>
        </div>
      </div>
    </div>

    <div class="col-md-6 mb-4">
      <div class="gh-card gh-card-elevated">
        <div class="gh-card-header">
          <h5 class="mb-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
              <path d="M3 3v18h18"></path>
              <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"></path>
            </svg>
            Statistics
          </h5>
        </div>
        <div class="gh-card-body">
          <p class="text-muted">View your usage statistics</p>
          <%= link_to "View Statistics", account_statistics_path, class: "btn btn-primary" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Messages -->
  <% if @recent_messages.any? %>
    <div class="gh-card">
      <div class="gh-card-header">
        <h5 class="mb-0">Recent Messages</h5>
        <%= link_to "View All", account_messages_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <div class="gh-card-body">
        <div class="table-responsive">
          <table class="table table-sm">
            <thead>
              <tr>
                <th>Label</th>
                <th>Type</th>
                <th>Created</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_messages.each do |message| %>
                <tr>
                  <td><%= message.encrypted_label || "Untitled" %></td>
                  <td><%= message.message_type.capitalize %></td>
                  <td><%= message.created_at.strftime("%b %d") %></td>
                  <td>
                    <% if message.expired? %>
                      <span class="badge bg-secondary">Expired</span>
                    <% else %>
                      <span class="badge bg-success">Active</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>

  <div class="mt-4 text-center">
    <%= link_to "Log Out", session_path, method: :delete, class: "btn btn-outline-danger" %>
  </div>
</div>
