<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Usage Statistics</h2>
    <%= link_to "Back to Dashboard", account_dashboard_path, class: "btn btn-outline-secondary" %>
  </div>

  <div class="row mb-4">
    <div class="col-md-4 mb-3">
      <div class="gh-card">
        <div class="gh-card-body text-center">
          <h3 class="text-primary"><%= @stats[:total_messages] %></h3>
          <p class="text-muted mb-0">Total Messages</p>
        </div>
      </div>
    </div>
    <div class="col-md-4 mb-3">
      <div class="gh-card">
        <div class="gh-card-body text-center">
          <h3 class="text-success"><%= @stats[:active_messages] %></h3>
          <p class="text-muted mb-0">Active Messages</p>
        </div>
      </div>
    </div>
    <div class="col-md-4 mb-3">
      <div class="gh-card">
        <div class="gh-card-body text-center">
          <h3 class="text-secondary"><%= @stats[:expired_messages] %></h3>
          <p class="text-muted mb-0">Expired Messages</p>
        </div>
      </div>
    </div>
  </div>

  <% if @stats[:messages_by_type].any? %>
    <div class="gh-card">
      <div class="gh-card-header">
        <h5>Messages by Type</h5>
      </div>
      <div class="gh-card-body">
        <% @stats[:messages_by_type].each do |type, count| %>
          <div class="d-flex justify-content-between mb-2">
            <span><%= type&.capitalize || "Unknown" %></span>
            <span class="badge bg-primary"><%= count %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
