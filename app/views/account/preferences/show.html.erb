<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Account Preferences</h2>
    <%= link_to "Back to Dashboard", account_dashboard_path, class: "btn btn-outline-secondary" %>
  </div>

  <div class="gh-card">
    <div class="gh-card-header">
      <h3>Default Settings</h3>
    </div>
    <div class="gh-card-body">
      <%= form_with model: @user_preference, url: account_preferences_path, local: true do |form| %>
        <div class="mb-3">
          <%= form.label :default_ttl, "Default Expiration Time", class: "form-label" %>
          <%= form.select :default_ttl,
              options_for_select([
                ['1 hour', 3600],
                ['1 day', 86400],
                ['1 week', 604800]
              ], @user_preference.default_ttl || 86400),
              {}, { class: "form-select" } %>
        </div>

        <div class="mb-3">
          <%= form.label :default_views, "Default View Limit", class: "form-label" %>
          <%= form.select :default_views,
              options_for_select([
                ['1 view', 1],
                ['2 views', 2],
                ['3 views', 3],
                ['5 views', 5]
              ], @user_preference.default_views || 1),
              {}, { class: "form-select" } %>
        </div>

        <div class="mb-3">
          <%= form.label :theme_preference, "Theme Preference", class: "form-label" %>
          <%= form.select :theme_preference,
              options_for_select([
                ['Auto (System)', 'auto'],
                ['Light', 'light'],
                ['Dark', 'dark']
              ], @user_preference.theme_preference || 'auto'),
              {}, { class: "form-select" } %>
        </div>

        <div class="d-grid">
          <%= form.submit "Save Preferences", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-4">
    <%= link_to "Log Out", session_path, method: :delete, class: "btn btn-outline-danger" %>
  </div>
</div>
