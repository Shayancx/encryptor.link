<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>encryptor.link - Debug Mode</title>
  <%= csrf_meta_tags %>
  
  <% if Rails.env.development? %>
    <!-- Development: Direct Vite URLs -->
    <script type="module" src="http://localhost:3036/vite-dev/@vite/client"></script>
    <script type="module" src="http://localhost:3036/vite-dev/entrypoints/application.tsx"></script>
  <% else %>
    <!-- Production: Use vite_rails helpers -->
    <%= vite_client_tag %>
    <%= vite_stylesheet_tag 'application' %>
    <%= vite_javascript_tag 'application', type: 'module' %>
  <% end %>
</head>
<body style="margin: 0; font-family: system-ui, sans-serif;">
  <!-- React root element -->
  <div id="react-root">
    <!-- Fallback content while React loads -->
    <div style="padding: 20px; background: #333; color: white; min-height: 100vh;">
      <h1>⏳ Loading React...</h1>
      <p>If this message persists, check the browser console for errors.</p>
      <div style="margin-top: 10px; font-size: 12px; opacity: 0.7;">
        Debug: Loading from Vite server at localhost:3036
      </div>
    </div>
  </div>

  <!-- Debug info -->
  <script>
    console.log("📄 HTML loaded")
    console.log("🎯 React root element exists:", !!document.getElementById('react-root'))
    console.log("🔗 Environment:", "<%= Rails.env %>")
    
    // Wait a bit and check if React mounted
    setTimeout(() => {
      const rootEl = document.getElementById('react-root')
      const content = rootEl ? rootEl.innerHTML : ''
      if (content.includes('Loading React')) {
        console.error("❌ React failed to mount - fallback content still visible")
        console.log("📊 Checking Vite server...")
        fetch('http://localhost:3036/vite-dev/entrypoints/application.tsx')
          .then(response => {
            console.log("Vite response status:", response.status)
            console.log("Vite response content-type:", response.headers.get('content-type'))
            return response.text()
          })
          .then(text => {
            console.log("Vite file content (first 200 chars):", text.substring(0, 200))
          })
          .catch(error => {
            console.error("❌ Cannot reach Vite server:", error)
          })
      } else {
        console.log("✅ React appears to have mounted successfully")
      }
    }, 3000)
  </script>
</body>
</html>
