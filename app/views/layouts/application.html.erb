<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>encryptor.link - Zero-Knowledge Encryption</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= vite_stylesheet_tag 'application' %>

  <!-- GitHub-style favicon -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 16 16%22><path fill-rule=%22evenodd%22 d=%22M8 1.5a6.5 6.5 0 0 0-2.05 12.675c.325.057.443-.141.443-.313l-.001-1.204c-1.8.388-2.183-.435-2.183-.435-.295-.747-.718-.945-.718-.945-.587-.402.044-.394.044-.394.649.046.99.663.99.663.577.99 1.514.704 1.883.538.058-.418.226-.703.41-.866-1.437-.163-2.947-.719-2.947-3.197 0-.706.252-1.284.665-1.736-.069-.164-.29-.823.063-1.714 0 0 .543-.174 1.777.663A6.195 6.195 0 0 1 8 5.037c.554 0 1.112.074 1.634.22 1.234-.837 1.775-.663 1.775-.663.354.891.131 1.55.066 1.714.416.452.667 1.03.667 1.736 0 2.485-1.513 3.032-2.955 3.19.23.198.439.59.439 1.19l-.001 1.762c0 .174.117.374.444.31A6.5 6.5 0 0 0 8 1.5z%22></path></svg>" />
  <%= vite_client_tag %>
  <%= vite_javascript_tag 'application', type: 'module' %>

</head>
<body data-controller="rate-limit">
  <div id="root"></div>

  <header class="bg-gray-800 text-white border-b sticky top-0">
    <div class="max-w-4xl mx-auto flex items-center justify-between gap-4 p-4">
      <a href="/" class="text-xl font-semibold">encryptor.link</a>
      <a href="/check" class="text-sm text-gray-400 hover:text-white">Check Link Status</a>

      <div data-controller="theme">
        <button type="button" id="themeToggle" aria-label="Toggle theme" class="p-2" data-action="click->theme#toggle" data-theme-target="button">
            <svg id="sun-icon" data-theme-target="sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="m12 2 0 2"></path>
              <path d="m12 20 0 2"></path>
              <path d="m4.93 4.93 1.41 1.41"></path>
              <path d="m17.66 17.66 1.41 1.41"></path>
              <path d="m2 12 2 0"></path>
              <path d="m20 12 2 0"></path>
              <path d="m6.34 17.66-1.41 1.41"></path>
              <path d="m19.07 4.93-1.41 1.41"></path>
            </svg>
            <svg id="moon-icon" data-theme-target="moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </header>

  <main class="max-w-4xl mx-auto p-4">
    <%= yield %>
  </main>

  <footer class="border-t py-4 text-center text-xs text-gray-500">
    <p>Zero-knowledge, client-side encrypted messages</p>
    <p>All encryption and decryption happens in your browser. The server never sees your plaintext data.</p>
  </footer>

</body>
</html>
